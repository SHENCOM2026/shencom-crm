{
  "name": "shencom-crm",
  "version": "1.0.0",
  "description": "CRM de Ventas para SHENCOM - Distribuidor Autorizado Claro Ecuador",
  "main": "server/index.js",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\" \"npm run mobile\"",
    "server": "nodemon server/index.js",
    "client": "cd client && npx vite --port 5173",
    "mobile": "cd mobile && npx vite --port 5174",
    "build": "cd client && npx vite build && cd ../mobile && npx vite build",
    "build:mobile": "cd mobile && npx vite build",
    "start": "NODE_ENV=production node server/index.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.7.0",
    "cors": "^2.8.5",
    "csv-parse": "^5.6.0",
    "csv-stringify": "^6.5.2",
    "exceljs": "^4.4.0",
    "express": "^4.21.0",
    "googleapis": "^171.4.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "normalize-path": "^3.0.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "nodemon": "^3.1.0"
  }
}
